{
  "name": "Image Display",
  "version": "1.2.16",
  "description": "Displays any local or remote image as a fullscreen background layer",
  "author": "MyWallpaper",
  "type": "widget",
  "entry": "index.js",
  "categories": [
    "backgrounds",
    "media",
    "utility"
  ],
  "license": "MIT",
  "settings": {
    "sourceType": {
      "type": "select",
      "content": {
        "label": "Image source",
        "default": "url",
        "options": [
          {
            "label": "Image URL",
            "value": "url"
          },
          {
            "label": "Local image",
            "value": "local"
          }
        ]
      }
    },
    "wallpaperImage": {
      "type": "image",
      "content": {
        "label": "Choose local image",
        "showIf": {
          "setting": "sourceType",
          "equals": "local"
        }
      }
    },
    "imageUrl": {
      "type": "string",
      "content": {
        "label": "Paste image URL",
        "default": "",
        "showIf": {
          "setting": "sourceType",
          "equals": "url"
        }
      }
    },
    "objectFit": {
      "type": "select",
      "content": {
        "label": "Fit image",
        "default": "cover",
        "options": [
          {
            "label": "Fill frame",
            "value": "cover"
          },
          {
            "label": "Show whole image",
            "value": "contain"
          },
          {
            "label": "Stretch image",
            "value": "fill"
          }
        ]
      }
    }
  },
  "permissions": {
    "fileAccess": true,
    "network": {
      "read": true,
      "domains": [
        "*"
      ]
    }
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100,
    "rotation": 0
  },
  "ui": {
    "pointerEvents": "none"
  },
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-image-display"
}
