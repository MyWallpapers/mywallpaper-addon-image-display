{
  "runtime": "canvas-v1",
  "name": "Image Display",
  "description": "Displays a live image URL as a full-layer background.",
  "version": "2.1.2",
  "entry": "dist/index.html",
  "thumbnail": "assets/thumbnail.png",
  "deviceSettingsVersion": "1",
  "ui": {
    "pointerEvents": "none"
  },
  "settings": [
    {
      "id": "imageUrl",
      "type": "string",
      "label": "Image URL",
      "description": "Paste a public HTTP(S), data or blob image URL.",
      "default": "",
      "placeholder": "https://example.com/image.jpg"
    },
    {
      "id": "objectFit",
      "type": "select",
      "label": "Fit image",
      "default": "cover",
      "options": [
        {
          "label": "Fill frame",
          "value": "cover"
        },
        {
          "label": "Show whole image",
          "value": "contain"
        },
        {
          "label": "Stretch image",
          "value": "fill"
        }
      ]
    }
  ]
}
