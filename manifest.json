{
  "name": "Image Display",
  "version": "1.2.2",
  "description": "Displays an image as a fullscreen background layer",
  "author": "MyWallpaper",
  "entry": "index.js",
  "settings": {
    "sourceType": {
      "type": "select",
      "content": {
        "label": "Image Source",
        "default": "local",
        "options": [
          {
            "label": "Local Upload",
            "value": "local"
          },
          {
            "label": "Online URL",
            "value": "url"
          }
        ]
      }
    },
    "wallpaperImage": {
      "type": "image",
      "content": {
        "label": "Upload Image",
        "showIf": {
          "setting": "sourceType",
          "equals": "local"
        }
      }
    },
    "imageUrl": {
      "type": "string",
      "content": {
        "label": "Image URL",
        "default": "",
        "showIf": {
          "setting": "sourceType",
          "equals": "url"
        }
      }
    }
  },
  "permissions": {
    "fileAccess": true
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100
  },
  "ui": {
    "pointerEvents": "none"
  }
}
