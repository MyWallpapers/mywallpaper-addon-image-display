{
  "name": "Image Display",
  "version": "2.0.0",
  "description": "Displays a remote image URL as a fullscreen background layer",
  "author": "MyWallpaper",
  "type": "addon",
  "runtime": "trusted-browser-v1",
  "entry": "dist/index.html",
  "categories": [
    "backgrounds",
    "media",
    "utility"
  ],
  "license": "MIT",
  "settings": {
    "imageUrl": {
      "type": "string",
      "content": {
        "label": "Paste image URL",
        "default": ""
      }
    },
    "objectFit": {
      "type": "select",
      "content": {
        "label": "Fit image",
        "default": "cover",
        "options": [
          {
            "label": "Fill frame",
            "value": "cover"
          },
          {
            "label": "Show whole image",
            "value": "contain"
          },
          {
            "label": "Stretch image",
            "value": "fill"
          }
        ]
      }
    }
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100,
    "rotation": 0
  },
  "ui": {
    "pointerEvents": "none"
  },
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-image-display"
}
